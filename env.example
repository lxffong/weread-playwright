# WeRead 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# 环境变量会覆盖 config.yaml 中的配置

# 浏览器配置
WEREAD_HEADLESS=false

# 文件路径
WEREAD_COOKIES_FILE=cookies.json

# 阅读配置
# 书籍 ID（逗号分隔，如果配置则从中随机选择）
WEREAD_BOOK_IDS=276323e0813ab90a5g0144d7,another_book_id
WEREAD_BOOK_INDEX=0
WEREAD_SPEED=medium
WEREAD_DURATION=30

# 定时任务
WEREAD_SCHEDULE_ENABLED=false
WEREAD_SCHEDULE_CRON=0 9 * * *

# TODO: 邮件通知
WEREAD_EMAIL_ENABLED=false
WEREAD_EMAIL_SMTP=smtp.gmail.com
WEREAD_EMAIL_PORT=587
WEREAD_EMAIL_FROM=your-email@gmail.com
WEREAD_EMAIL_TO=recipient@gmail.com
WEREAD_EMAIL_PASSWORD=your-app-password
WEREAD_EMAIL_SECURITY=auto  # auto, ssl, tls, none

# Bark 推送
WEREAD_BARK_ENABLED=false
WEREAD_BARK_URL=https://api.day.app/your-key
